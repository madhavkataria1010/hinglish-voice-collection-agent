# Copy this file to .env and fill in your values.
# NEVER commit the real .env — it's in .gitignore.

# ── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Any OpenAI Chat Completions model id works. gpt-4o is the default —
# strong on the no-rupee-digits-in-text rule and code-switched Hinglish.
# Tested alternatives: gpt-4o-mini (lower TTFT, slightly weaker tool-call
# discipline), gpt-5.x-mini-* if you have access.
OPENAI_MODEL=gpt-4o

# ── TTS ──────────────────────────────────────────────────────────────────────
# Sarvam Bulbul-v2: most natural Hinglish voice. Single multilingual voice
# eliminates the "switch pause" failure mode at the physical layer.
SARVAM_API_KEY=...
# Optional Cartesia fallback (used only if SARVAM_API_KEY is empty)
CARTESIA_API_KEY=

# ── STT backend ──────────────────────────────────────────────────────────────
# "remote" — posts WAV to a GPU server over SSH tunnel (recommended for live
#            agent; ~370ms warm latency; see remote_stt/ for the server).
# "local"  — runs faster-whisper on the laptop CPU. Self-contained but slow
#            on large-v3 (~9-10s per turn on Apple Silicon int8).
WHISPER_BACKEND=remote
WHISPER_REMOTE_URL=http://localhost:8765

# Local-only knobs (ignored when WHISPER_BACKEND=remote)
WHISPER_MODEL=large-v3
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=auto

# Whisper language hint. "hi" keeps transcripts in Devanagari/Latin and
# prevents Urdu mistranscription on Hinglish input. Whisper-Hindi-mode
# still handles English code-switch inline within the same forward pass.
WHISPER_LANGUAGE=hi

# Optional vocabulary bias for the Whisper decoder. WhisperSTTService
# auto-builds one from BORROWER_NAME + collections vocabulary; only set
# this if you want to override that default.
# WHISPER_INITIAL_PROMPT=

# ── Pipeline tuning ──────────────────────────────────────────────────────────
# VAD silence before end-of-utterance fires (ms).
VAD_SILENCE_MS=250
# Extra speech-timeout on top of VAD (seconds).
USER_SPEECH_TIMEOUT_S=0.3
# Safety ceiling: fire even if no transcript arrived (seconds).
USER_TURN_STOP_TIMEOUT_S=2.0

# Backchannel filler ("haan ji" / "achha"). OFF by default — in live use
# the random interjections feel like the bot interrupting. Worth turning
# on when benchmarking perceived latency (filler fires in ~50ms, before
# LLM TTFT).
FILLER_ENABLED=false

LOG_LEVEL=INFO

# ── Web entry point (agent_web.py) ───────────────────────────────────────────
# Bind for the FastAPI server. 127.0.0.1 is fine for local; use 0.0.0.0
# inside Docker.
WEB_HOST=127.0.0.1
WEB_PORT=7860

# ── Demo / call setup ────────────────────────────────────────────────────────
# Name the LLM should greet the borrower with. Also injected into Whisper's
# initial_prompt for proper-noun bias (so "Madhav" stops being heard as
# "वादव").
BORROWER_NAME=Madhav
# Principal outstanding (INR). Min settlement = 70% of this.
PRINCIPAL_INR=125000

# ── Eval baseline only ───────────────────────────────────────────────────────
# Not required to run the agent — only needed for `make eval-baseline`.
# If unset or rejected, the eval falls back to OpenAI's hosted Whisper API
# as the commercial baseline.
DEEPGRAM_API_KEY=

# ── HuggingFace (optional) ───────────────────────────────────────────────────
# Only needed if you want to download Whisper weights from the HF mirror
# rather than CTranslate2's default source.
HF_TOKEN=
