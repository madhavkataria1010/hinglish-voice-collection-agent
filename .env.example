# Copy this file to .env and fill in your values.
# NEVER commit the real .env — it's in .gitignore.

# ── LLM ─────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Latest mini model — fast TTFT, good Hinglish instruction-following.
# Any OpenAI Chat Completions model id works here.
OPENAI_MODEL=gpt-4o-mini

# ── TTS ──────────────────────────────────────────────────────────────────────
# Sarvam Bulbul-v2: most natural Hinglish voice, single model for hi + en.
SARVAM_API_KEY=...
# Optional Cartesia fallback (used only if SARVAM_API_KEY is empty)
CARTESIA_API_KEY=

# ── STT backend ──────────────────────────────────────────────────────────────
# "remote" (default) — posts WAV to a GPU server over SSH tunnel.
# "local"            — runs faster-whisper on the laptop CPU (slow on large-v3).
WHISPER_BACKEND=remote
WHISPER_REMOTE_URL=http://localhost:8765

# Local-only knobs (ignored when WHISPER_BACKEND=remote)
WHISPER_MODEL=large-v3-turbo
WHISPER_COMPUTE_TYPE=int8
WHISPER_DEVICE=auto

# Whisper language hint. "hi" keeps transcripts in Devanagari/Latin and
# prevents Urdu mistranscription on Hinglish input.
WHISPER_LANGUAGE=hi

# ── Pipeline tuning ──────────────────────────────────────────────────────────
# VAD silence before end-of-utterance fires (ms).
VAD_SILENCE_MS=250
# Extra speech-timeout on top of VAD (seconds).
USER_SPEECH_TIMEOUT_S=0.3
# Safety ceiling: fire even if no transcript arrived (seconds).
USER_TURN_STOP_TIMEOUT_S=2.0

# Backchannel filler ("haan ji" / "achha"). OFF by default — feels
# like an interruption in practice. Set to true when benchmarking
# perceived latency (filler fires in ~300ms, before LLM TTFT).
FILLER_ENABLED=false

LOG_LEVEL=INFO

# ── Demo / call setup ────────────────────────────────────────────────────────
# Name the LLM should greet the borrower with.
BORROWER_NAME=Madhav
# Principal outstanding (INR). Min settlement = 70% of this.
PRINCIPAL_INR=125000

# ── Eval baseline only ───────────────────────────────────────────────────────
# Not required to run the agent — only needed for make eval-baseline.
DEEPGRAM_API_KEY=

# ── HuggingFace (optional) ───────────────────────────────────────────────────
HF_TOKEN=hf_...
