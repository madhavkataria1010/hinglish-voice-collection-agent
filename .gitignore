# Python
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# Environment — NEVER commit real keys
.env
.env.local
.env.*.local

# Claude Code session data
.claude/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor
.vscode/
.idea/
*.swp
*.swo

# Build artefacts
demo/recording.wav
demo/*.mp4
demo/*.mov
demo/*.m4a

# eval/report.md and eval/results/*.jsonl ARE committed — they are
# deliverables ("measurement report with raw data"). Regenerate with
# `make eval`. Audio fixtures generated by synth_corpus stay out of git
# (they're large and reproducible from gold transcripts).
eval/test_corpus/*.wav

# Model weights (large binaries)
*.ckpt
*.pt
*.bin
models/

# uv — lock file IS committed (reproducible installs)
# uv.lock  ← intentionally not ignored
